--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7420c67ef41702345a3c75c2fb879a81, type: 3}
  m_Name: BinaPhoneCall
  m_EditorClassIdentifier: 
  lockPlayer: 0
  lines:
  - speaker: 2
    text: 'Suara wanita yang familiar terdengar dari suara telepon '
    autoAdvanceDelay: 0
  - speaker: 1
    text: "\u201Challo selamat pagi\u201D  "
    autoAdvanceDelay: 0
  - speaker: 1
    text: "\u201CSelamat pagi A? Sudah sarapan?\u201D"
    autoAdvanceDelay: 0
  - speaker: 0
    text: "\u201CSudah, kamu gimana Bina\u201D,"
    autoAdvanceDelay: 0
  - speaker: 1
    text: "\u201CIya sudah juga-"
    autoAdvanceDelay: 0
  - speaker: 1
    text: aku mau siap-siap untuk berangkat kerja nih-
    autoAdvanceDelay: 0
  - speaker: 1
    text: 'omong omong gimana progres kasus yang kamu ambil ini? Apa kamu yakin mau
      lanjutin kasusnya?- '
    autoAdvanceDelay: 0
  - speaker: 1
    text: "Denger denger pemerintah gak suka kalau ada orang yang mau mencoba mencari
      bukti kebenaran\u201D, "
    autoAdvanceDelay: 0
  - speaker: 2
    text: Aku menghela napas
    autoAdvanceDelay: 0
  - speaker: 0
    text: "\"tenang aja bina, kita udah lama kenal, kamu tau kan aku gak kayak gitu\u201D"
    autoAdvanceDelay: 0
  - speaker: 1
    text: "\u201Cya gimana ya, kamu tau kan pemerintah kita kayak begitu, intinya
      karena kita bekerja sebagai tim, aku harap kamu lebih mengkhawatirkan keselamatanmu
      sendiri\""
    autoAdvanceDelay: 0
  - speaker: 0
    text: " \u201Ciya sama kamu juga, jangan terlalu menguak terlalu dalam ya\u201D"
    autoAdvanceDelay: 0
  - speaker: 1
    text: " \u201Ctentu saja, aku akan pergi ke kantor dulu ya, see you there\u201D "
    autoAdvanceDelay: 0
  - speaker: 0
    text: "\u201Ciya hati hati dijalan, bye\u201D"
    autoAdvanceDelay: 0
  - speaker: 2
    text: Telepon dimatikan
    autoAdvanceDelay: 0
  - speaker: 2
    text: "\u201CMaaf bina, tapi bagaimanapun juga, aku harus mencari tahu siapa
      dalangnya\u201D"
    autoAdvanceDelay: 0
